# API Configuration
VITE_API_URL=http://localhost:8000/api/v1

# Note: Password requirements are configured via the API environment variable MIN_PASSWORD_LENGTH
# The UI fetches these requirements dynamically from the /auth/password-requirements endpoint

# Analytics Configuration (Optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Marketing Configuration (Optional)
VITE_GOOGLE_ADS_ID=AW-XXXXXXXXX
VITE_GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX/XXXXXXXXX
VITE_FACEBOOK_PIXEL_ID=XXXXXXXXXXXXXXXXX
VITE_LINKEDIN_PARTNER_ID=XXXXXXX

# Other Analytics Providers (Optional)
VITE_MIXPANEL_TOKEN=your_mixpanel_token
VITE_HOTJAR_ID=your_hotjar_id
VITE_INTERCOM_APP_ID=your_intercom_app_id

# Development/Production Environment
VITE_ENVIRONMENT=development
