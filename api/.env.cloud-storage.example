# Cloud Storage Configuration Template
# Copy this file to .env and configure your cloud storage providers

# =====================================================
# CLOUD STORAGE GENERAL SETTINGS
# =====================================================

# Primary storage provider: aws_s3, azure_blob, gcp_storage, local
CLOUD_STORAGE_PRIMARY_PROVIDER=local

# Enable automatic fallback to local storage when cloud providers fail
CLOUD_STORAGE_FALLBACK_ENABLED=true

# Enable cloud storage migration (set to false to disable cloud storage entirely)
CLOUD_STORAGE_ENABLED=false

# =====================================================
# AWS S3 CONFIGURATION
# =====================================================

# Enable AWS S3 storage provider
AWS_S3_ENABLED=false

# AWS S3 bucket name (required if AWS_S3_ENABLED=true)
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# AWS region for S3 bucket
AWS_S3_REGION=us-east-1

# AWS credentials (use IAM roles in production)
AWS_S3_ACCESS_KEY_ID=your-aws-access-key-id
AWS_S3_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Optional: S3 endpoint URL (for S3-compatible services like MinIO)
# AWS_S3_ENDPOINT_URL=https://s3.amazonaws.com

# Optional: S3 storage class (STANDARD, STANDARD_IA, ONEZONE_IA, REDUCED_REDUNDANCY)
AWS_S3_STORAGE_CLASS=STANDARD

# Optional: Enable S3 server-side encryption (AES256, aws:kms)
AWS_S3_SERVER_SIDE_ENCRYPTION=AES256

# Optional: KMS key ID for aws:kms encryption
# AWS_S3_KMS_KEY_ID=your-kms-key-id

# =====================================================
# AZURE BLOB STORAGE CONFIGURATION
# =====================================================

# Enable Azure Blob Storage provider
AZURE_BLOB_ENABLED=false

# Azure Storage Account name (required if AZURE_BLOB_ENABLED=true)
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name

# Azure Storage Account key or connection string
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
# Alternative: Use connection string instead of account name/key
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Blob container name
AZURE_CONTAINER_NAME=attachments

# Optional: Azure storage tier (Hot, Cool, Archive)
AZURE_BLOB_TIER=Hot

# Optional: Enable Azure Blob encryption
AZURE_BLOB_ENCRYPTION_ENABLED=true

# =====================================================
# GOOGLE CLOUD STORAGE CONFIGURATION
# =====================================================

# Enable Google Cloud Storage provider
GCP_STORAGE_ENABLED=false

# GCP project ID (required if GCP_STORAGE_ENABLED=true)
GCP_PROJECT_ID=your-gcp-project-id

# GCP Storage bucket name
GCP_BUCKET_NAME=your-gcs-bucket-name

# GCP region for bucket
GCP_STORAGE_REGION=us-central1

# Path to service account credentials JSON file
GCP_CREDENTIALS_PATH=/path/to/service-account-key.json
# Alternative: Use service account key content directly
# GCP_CREDENTIALS_JSON={"type": "service_account", ...}

# Optional: GCP storage class (STANDARD, NEARLINE, COLDLINE, ARCHIVE)
GCP_STORAGE_CLASS=STANDARD

# =====================================================
# STORAGE OPTIMIZATION SETTINGS
# =====================================================

# Enable automatic storage class optimization based on access patterns
STORAGE_COST_OPTIMIZATION_ENABLED=true

# Days after which files are moved to cheaper storage tiers
STORAGE_TIER_TRANSITION_DAYS=30

# Days after which files are archived (if supported by provider)
STORAGE_ARCHIVE_DAYS=365

# Days after which files are deleted (0 = never delete)
STORAGE_RETENTION_DAYS=0

# Maximum storage cost per month (USD) before alerts are triggered
STORAGE_COST_ALERT_THRESHOLD=100.00

# =====================================================
# MONITORING AND LOGGING SETTINGS
# =====================================================

# Enable detailed storage operation logging
STORAGE_OPERATION_LOGGING_ENABLED=true

# Enable storage performance monitoring
STORAGE_PERFORMANCE_MONITORING_ENABLED=true

# Storage health check interval (seconds)
STORAGE_HEALTH_CHECK_INTERVAL=300

# Circuit breaker failure threshold (number of failures before opening circuit)
STORAGE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Circuit breaker recovery timeout (seconds)
STORAGE_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# =====================================================
# MIGRATION SETTINGS
# =====================================================

# Enable automatic migration of new files to cloud storage
STORAGE_AUTO_MIGRATION_ENABLED=true

# Batch size for migration operations
STORAGE_MIGRATION_BATCH_SIZE=100

# Maximum concurrent migration operations
STORAGE_MIGRATION_MAX_CONCURRENT=5

# Enable migration integrity verification using checksums
STORAGE_MIGRATION_VERIFY_INTEGRITY=true

# =====================================================
# SECURITY SETTINGS
# =====================================================

# Enable tenant isolation in cloud storage (recommended: true)
STORAGE_TENANT_ISOLATION_ENABLED=true

# Presigned URL expiration time (seconds)
STORAGE_PRESIGNED_URL_EXPIRY=3600

# Enable audit logging for all storage operations
STORAGE_AUDIT_LOGGING_ENABLED=true

# Maximum file size for cloud storage uploads (bytes)
STORAGE_MAX_FILE_SIZE=104857600  # 100MB

# Allowed file extensions (comma-separated, empty = all allowed)
STORAGE_ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,gif,doc,docx,xls,xlsx,txt,csv

# =====================================================
# DISASTER RECOVERY SETTINGS
# =====================================================

# Enable cross-region replication (provider-specific)
STORAGE_CROSS_REGION_REPLICATION_ENABLED=false

# Secondary region for disaster recovery
STORAGE_SECONDARY_REGION=us-west-2

# Enable file versioning for disaster recovery
STORAGE_VERSIONING_ENABLED=false

# Maximum number of file versions to keep
STORAGE_MAX_VERSIONS=5

# Enable automatic backup to secondary storage
STORAGE_BACKUP_ENABLED=false

# Backup frequency (daily, weekly, monthly)
STORAGE_BACKUP_FREQUENCY=daily