{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "typeRoots": ["../../ui/node_modules/@types"],
    "paths": {
      "react": ["../../ui/node_modules/react"],
      "react/*": ["../../ui/node_modules/react/*"],
      "react-dom": ["../../ui/node_modules/react-dom"],
      "react-dom/*": ["../../ui/node_modules/react-dom/*"],
      "react-router-dom": ["../../ui/node_modules/react-router-dom"],
      "react-router-dom/*": ["../../ui/node_modules/react-router-dom/*"]
    }
  },
  "include": ["ui/**/*.tsx", "ui/**/*.ts"]
}
