# URL of the main YourFinanceWORKS instance
# Use http://localhost:8000 for local dev with YFW stack
# Use https://demo.yourfinanceworks.com to test against demo
YFW_API_URL=http://localhost:8000
# YFW_API_URL=https://demo.yourfinanceworks.com

# Your YFW API key
YFW_API_KEY=ak_your_key_here

# Development/Mock Modes
# Set to 'true' to allow bypassing health checks with 'ak_dev' key
DEVELOPMENT_MODE=false
# Set to 'true' to bypass ALL auth health checks (not for production!)
MOCK_YFW_API=false

SECRET_KEY=change-me-in-production
SURVEYS_DATABASE_URL=sqlite:///./surveys.db
API_PORT=8001
UI_PORT=3001
