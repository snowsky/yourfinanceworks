# License Key Configuration
# 
# This file shows examples of how to configure license public keys
# using environment variables instead of files.

# Default key version to use for licenses without explicit kid
LICENSE_DEFAULT_KEY_ID=v2

# Public key version 2 (current)
# Replace with your actual public key
LICENSE_PUBLIC_KEY_V2="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAzexH7ckqeuCg2ZmyiMFS
7E9M7BUQn5Sase7Aus3pXwo9O5Kw0gq2ukgR32m6isAo5CV/CpyUgjPgVnJqPyYW
gm7fvoU5NrKESPjdnvqZrpy9ygcfAp67RX0wQaqqSSAFboq4AbPPR3tlTYIIGOC/
sy8MvcwsepJyDvUWxc07YJh8X1JVYuyQn/fD9D7OTMjQkevDC/LGhGgvm3dcxutt
wyVLDzTYV9zdw0bLzi45xLcevDFQxag20ZjTwWR7LWCVqJd4jRgktHmhUzDAAVs2
QVZyeUOG6EdWQcPZ7lArmtrb4rnWRgsthFggKBZWHDBhhiaOjH5mUSNcPKV99rK0
DwIDAQAB
-----END PUBLIC KEY-----"

# Public key version 3 (new - after key rotation)
# Uncomment and add your new public key when rotating keys
# LICENSE_PUBLIC_KEY_V3="-----BEGIN PUBLIC KEY-----
# ...your new public key...
# -----END PUBLIC KEY-----"

# Public key version 1 (old - for backward compatibility)
# Uncomment if you need to support old licenses
# LICENSE_PUBLIC_KEY_V1="-----BEGIN PUBLIC KEY-----
# ...your old public key...
# -----END PUBLIC KEY-----"

# Notes:
# - Environment variables take priority over files
# - You can mix env vars and files (env vars override)
# - Keep the BEGIN/END markers and newlines intact
# - Multiple key versions can coexist for key rotation
