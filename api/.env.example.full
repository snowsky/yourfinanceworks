LOG_LEVEL=DEBUG

# UI
UI_BASE_URL=http://localhost:8080

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:password@postgres:5432/invoice_app

# JWT Settings
SECRET_KEY=your-super-secret-key-here-change-this-in-production
JWT_SECRET_KEY=AeSu6Ewi
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Password Configuration
MIN_PASSWORD_LENGTH=8  # Minimum password length (default: 8)

# Email Configuration (optional)
EMAIL_SERVICE=ses  # ses, azure, mailgun, or smtp
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Cloud Storage Configuration
CLOUD_STORAGE_ENABLED=false
CLOUD_STORAGE_PRIMARY_PROVIDER=aws_s3
CLOUD_STORAGE_FALLBACK_ENABLED=true
CLOUD_STORAGE_FALLBACK_PROVIDER=local

# Enable AWS S3 storage provider
AWS_S3_ENABLED=false
# AWS S3 bucket name (required if AWS_S3_ENABLED=true)
AWS_S3_BUCKET_NAME=your-s3-bucket-name
# AWS region for S3 bucket
AWS_S3_REGION=us-east-1
# AWS credentials (use IAM roles in production)
AWS_S3_ACCESS_KEY_ID=your-aws-access-key-id
AWS_S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
# Optional: S3 storage class (STANDARD, STANDARD_IA, ONEZONE_IA, REDUCED_REDUNDANCY)
AWS_S3_STORAGE_CLASS=STANDARD
# Optional: Enable S3 server-side encryption (AES256, aws:kms)
AWS_S3_SERVER_SIDE_ENCRYPTION=AES256

# For Azure Email Services
AZURE_CONNECTION_STRING=your-azure-connection-string

# For Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain

# For SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Application Settings
DEBUG=True
HOST=0.0.0.0
PORT=8000

# AI Assistant Configuration
AI_ASSISTANT_ENABLED=true  # Enable/disable AI assistant features

# Feature Flags
FEATURE_PROMPT_MANAGEMENT_ENABLED=false  # Enable/disable prompt management feature

# CORS Configuration
# Comma-separated list of allowed origins for CORS, e.g.
# ALLOWED_ORIGINS=http://localhost:8080,https://app.example.com
ALLOWED_ORIGINS=http://localhost:8080
# Whether to allow credentials (cookies, Authorization headers) across origins.
# Note: This is ignored when ALLOWED_ORIGINS contains "*" per CORS spec.
ALLOW_CORS_CREDENTIALS=False

# SSO Configuration
GOOGLE_SSO_ENABLED=false
AZURE_SSO_ENABLED=false

# Google OAuth2 Configuration (required if GOOGLE_SSO_ENABLED=true)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Azure AD OAuth2 Configuration (required if AZURE_SSO_ENABLED=true)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=common  # 'common' for multi-tenant, or specific tenant ID

# Slack Integration Configuration
SLACK_VERIFICATION_TOKEN=your_slack_verification_token_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Optional: Slack App Configuration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Analytics Configuration
# Google Analytics 4
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GA_API_SECRET=your_ga_api_secret
# Mixpanel
MIXPANEL_TOKEN=your_mixpanel_token
# Custom Analytics Webhook
ANALYTICS_WEBHOOK_URL=https://your-analytics-api.com/events
ANALYTICS_API_KEY=your_api_key
# PostHog (Self-hosted or Cloud)
POSTHOG_API_KEY=your_posthog_key
POSTHOG_HOST=https://app.posthog.com
# Amplitude
AMPLITUDE_API_KEY=your_amplitude_key

# ---------------------- Kafka / OCR -------------------------
# Set to kafka:9092 when using docker-compose included Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_OCR_TOPIC=expenses_ocr
KAFKA_OCR_GROUP=invoice-app-ocr
KAFKA_BANK_TOPIC=bank_statements_ocr

# ---------------------- Bank Statement OCR Configuration -------------------------
# Enable/disable OCR fallback for bank statements
BANK_OCR_ENABLED=true

# OCR processing timeout in seconds
BANK_OCR_TIMEOUT=300

# Text quality thresholds for triggering OCR fallback
BANK_OCR_MIN_TEXT_THRESHOLD=50
BANK_OCR_MIN_WORD_THRESHOLD=10

# Unstructured API Configuration (optional - for cloud OCR)
UNSTRUCTURED_USE_API=false
UNSTRUCTURED_API_KEY=your-unstructured-api-key-here
UNSTRUCTURED_API_URL=https://api.unstructured.io

# Tesseract Configuration (for local OCR)
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_CONFIG=--oem 3 --psm 6

# UnstructuredLoader settings
UNSTRUCTURED_STRATEGY=hi_res
UNSTRUCTURED_MODE=single

# ---------------------- AI/LLM Configuration -------------------------
# These are fallback environment variables used when AI config is not set up in the database
# Priority: AI Config (database) → Environment Variables → Manual fallback

# AI Assistant Chat Configuration (Fallback)
# These settings are used when no AI configuration is found in the database
AI_PROVIDER=ollama              # Provider: ollama, openai, anthropic, google, custom
AI_MODEL=llama2                 # Model name (e.g., llama2, gpt-4, claude-3-opus)
AI_API_KEY=                     # API key (optional for Ollama, required for others)
AI_API_URL=http://localhost:11434  # API URL (required for Ollama and custom providers)

# Ollama OCR Configuration
# Set the complete endpoint URL for ollama-ocr library
# If not set, defaults to {OLLAMA_API_BASE}/api/generate
OLLAMA_OCR_ENDPOINT=http://host.docker.internal:11434/api/generate

# LLM Model Configuration
LLM_MODEL_INVOICES=gpt-4o-mini  # Specific model for invoice processing
LLM_MODEL=gpt-4o-mini           # General LLM model
OLLAMA_MODEL=gpt-oss:latest     # Ollama-specific model

# API Configuration
LLM_API_KEY=your-openai-api-key-here     # OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here  # Alternative OpenAI API key
LLM_API_BASE=http://localhost:11434      # Ollama API base URL
OLLAMA_API_BASE=http://localhost:11434   # Alternative Ollama API base URL

# Note: For production, it's recommended to configure AI settings through the web interface
# in Settings → AI Configuration rather than using environment variables

# Tax Service Integration
TAX_SERVICE_ENABLED=true
TAX_SERVICE_BASE_URL=http://192.168.86.39:8001
TAX_SERVICE_API_KEY=ak_Pw0viX75yYrLT8tUmS2c912gDDrLsR4qvtIO8XRrruU
TAX_SERVICE_TIMEOUT=30
TAX_SERVICE_RETRY_ATTEMPTS=3

# Development Environment Encryption Configuration
# Enable encryption in development
ENCRYPTION_ENABLED=true
# Use local key vault for development
KEY_VAULT_PROVIDER=local
MASTER_KEY_ID=dev-master-key
MASTER_KEY_PATH=/app/keys/master.key
# Faster key derivation for development (less secure but faster)
KEY_DERIVATION_ITERATIONS=10000
# Shorter rotation interval for testing
KEY_ROTATION_INTERVAL_DAYS=7
KEY_ROTATION_ENABLED=true
# Enable monitoring
ENCRYPTION_MONITORING_ENABLED=true
ENCRYPTION_METRICS_ENDPOINT=/metrics
# Development-specific settings
ENCRYPTION_KEY_CACHE_TTL=300
ENCRYPTION_BATCH_SIZE=100

# Kafka
KAFKA_OCR_TOPIC_PARTITIONS=2

# License Configuration
ALLOW_EXPIRED_LICENSES=false

# Auto-generate RSA key pairs (private/public keys) on startup if missing
# These keys are used to sign and verify license JWTs
LICENSE_KEY_AUTO_GENERATE=true

# License Key Request URL
LICENSE_KEY_REQUEST_URL=https://www.yourfinanceworks.com

# Feature Flags
FEATURE_ANOMALY_DETECTION_ENABLED=true

# License configuration for testing
LICENSE_KEY=
INSTALLATION_ID=
AUTO_ACTIVATE_LICENSE=true
