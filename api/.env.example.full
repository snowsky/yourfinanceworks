# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:password@postgres:5432/invoice_app

# JWT Settings
SECRET_KEY=your-super-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration (optional)
EMAIL_SERVICE=ses  # ses, azure, mailgun, or smtp
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# For Azure Email Services
AZURE_CONNECTION_STRING=your-azure-connection-string

# For Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain

# For SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Application Settings
DEBUG=True
HOST=0.0.0.0
PORT=8000

# CORS Configuration
# Comma-separated list of allowed origins for CORS, e.g.
# ALLOWED_ORIGINS=http://localhost:8080,https://app.example.com
ALLOWED_ORIGINS=http://localhost:8080
# Whether to allow credentials (cookies, Authorization headers) across origins.
# Note: This is ignored when ALLOWED_ORIGINS contains "*" per CORS spec.
ALLOW_CORS_CREDENTIALS=False

# Slack Integration Configuration
SLACK_VERIFICATION_TOKEN=your_slack_verification_token_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Optional: Slack App Configuration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Analytics Configuration
# Google Analytics 4
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GA_API_SECRET=your_ga_api_secret
# Mixpanel
MIXPANEL_TOKEN=your_mixpanel_token
# Custom Analytics Webhook
ANALYTICS_WEBHOOK_URL=https://your-analytics-api.com/events
ANALYTICS_API_KEY=your_api_key
# PostHog (Self-hosted or Cloud)
POSTHOG_API_KEY=your_posthog_key
POSTHOG_HOST=https://app.posthog.com
# Amplitude
AMPLITUDE_API_KEY=your_amplitude_key