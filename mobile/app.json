{
  "expo": {
    "name": "YourFinanceWORKS",
    "slug": "yourfinanceworks-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourfinanceworks.mobile",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to capture receipts and documents.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to select existing images.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save captured images to your photo library."
      }
    },
    "android": {
      "package": "com.yourfinanceworks.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      },
      "apiBaseUrl": "${EXPO_PUBLIC_API_BASE_URL}",
      "enableConsoleLogs": "${EXPO_PUBLIC_ENABLE_CONSOLE_LOGS:-false}"
    },
    "web": {
      "build": {
        "babel": {
          "include": ["@babel/preset-react"]
        }
      }
    }
  }
} 